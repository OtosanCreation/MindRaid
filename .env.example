# =========================================================
# MindRaid .env テンプレート
# 実運用時は .env にコピーして、値を埋める（.env は .gitignore 済み）
# =========================================================

# === 取引所切り替え ======================================
# "LIGHTER" = HL×Lighter DEX 構成（Phase 5 以降, 推奨）
# "MEXC"    = HL×MEXC 構成（Phase 4 までのレガシー構成）
EXCHANGE_MODE=LIGHTER

# === Lighter DEX =========================================
# Lighter UI → Settings → Export Key で取得する ETH 秘密鍵
# （Privy Embedded Wallet の L1 秘密鍵。0x プレフィックス不要）
LIGHTER_ETH_PRIVATE_KEY=

# system_setup.py 実行時に自動生成・登録される 40 byte API 秘密鍵
# 初回は空欄でOK。system_setup.py が .env に書き込む
LIGHTER_API_PRIVATE_KEY=

# Lighter Account Index（整数）
# Lighter UI または accounts_by_l1_address API から取得
LIGHTER_ACCOUNT_INDEX=

# === Hyperliquid =========================================
HL_PRIVATE_KEY=
HL_WALLET_ADDRESS=

# === MEXC（EXCHANGE_MODE=MEXC のときだけ必須）============
MEXC_API_KEY=
MEXC_API_SECRET=

# === Telegram 通知 =======================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
